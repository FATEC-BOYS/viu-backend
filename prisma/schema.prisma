generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 👤 Usuários
model Usuario {
  id       String  @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  email    String  @unique
  senha    String?
  nome     String
  telefone String?
  avatar   String?
  tipo     String  @default("DESIGNER") // TipoUsuario: DESIGNER, CLIENTE, ADMIN
  ativo    Boolean @default(true)

  // 2FA (Two-Factor Authentication)
  twoFactorEnabled     Boolean  @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[] @default([])

  // Email verification
  emailVerificado           Boolean   @default(false)
  emailVerificacaoToken     String?   @unique
  emailVerificacaoExpiresAt DateTime?

  // Password reset
  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?

  // Timestamps
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Relacionamentos existentes
  projetosDesigner Projeto[]       @relation("ProjetoDesigner")
  projetosCliente  Projeto[]       @relation("ProjetoCliente")
  artes            Arte[]          @relation("ArteAutor")
  feedbacks        Feedback[]      @relation("FeedbackAutor")
  aprovacoes       Aprovacao[]     @relation("AprovacaoAprovador")
  tarefas          Tarefa[]        @relation("TarefaResponsavel")
  notificacoes     Notificacao[]   @relation("NotificacaoUsuario")
  sessoes          Sessao[]        @relation("SessaoUsuario")
  auditLogs        AuditLog[]      @relation("AuditLogUsuario")
  securityEvents   SecurityEvent[] @relation("SecurityEventUsuario")

  // Relacionamentos de pagamento
  assinaturas         Assinatura[] @relation("AssinaturaUsuario")
  pagamentos          Pagamento[]  @relation("PagamentosUsuario")
  chavesPix           ChavePix[]   @relation("ChavesPixUsuario")
  saques              Saque[]      @relation("SaquesDesigner")
  faturasComoCliente  Fatura[]     @relation("FaturasCliente")
  faturasComoDesigner Fatura[]     @relation("FaturasDesigner")

  // Relacionamentos de proteção legal
  aceites         AceiteContratual[]
  disputasAbertas Disputa[]          @relation("DisputasAbertas")

  @@index([email])
  @@index([tipo])
  @@index([ativo])
  @@index([criadoEm])
  @@map("usuarios")
}

// 📁 Projetos
model Projeto {
  id        String    @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  nome      String
  descricao String?
  status    String    @default("EM_ANDAMENTO") // StatusProjeto: EM_ANDAMENTO, CONCLUIDO, CANCELADO
  orcamento Int? // Em centavos
  prazo     DateTime?

  // Relacionamentos
  designerId String
  designer   Usuario @relation("ProjetoDesigner", fields: [designerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clienteId  String
  cliente    Usuario @relation("ProjetoCliente", fields: [clienteId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  artes    Arte[]   @relation("ArtesProjeto")
  tarefas  Tarefa[] @relation("TarefasProjeto")
  faturas  Fatura[] @relation("FaturasProjeto")
  aceites  AceiteContratual[]
  disputas Disputa[]

  // Timestamps
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([designerId])
  @@index([clienteId])
  @@index([status])
  @@index([criadoEm])
  @@map("projetos")
}

// 🎨 Artes/Arquivos
model Arte {
  id        String  @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  nome      String
  descricao String?
  arquivo   String // URL/path do arquivo
  tipo      String // TipoArte: IMAGEM, VIDEO, PDF, etc
  tamanho   Int // Em bytes
  versao    Int     @default(1)
  status    String  @default("EM_ANALISE") // StatusArte: EM_ANALISE, APROVADO, REJEITADO

  // Relacionamentos
  projetoId String
  projeto   Projeto @relation("ArtesProjeto", fields: [projetoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  autorId   String
  autor     Usuario @relation("ArteAutor", fields: [autorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  feedbacks           Feedback[]          @relation("FeedbacksArte")
  aprovacoes          Aprovacao[]         @relation("AprovacoesArte")
  linksCompartilhados LinkCompartilhado[] @relation("LinksArte")

  // Timestamps
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([projetoId])
  @@index([autorId])
  @@index([status])
  @@index([tipo])
  @@index([criadoEm])
  @@map("artes")
}

// 💬 Feedbacks
model Feedback {
  id       String  @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  conteudo String
  tipo     String  @default("TEXTO") // TipoFeedback: TEXTO, AUDIO, POSICIONAL
  arquivo  String? // Para feedback de áudio
  posicaoX Float? // Para feedback posicional
  posicaoY Float?

  // Campos de transcrição / TTS
  transcricao String? // Texto transcrito a partir do áudio (STT)
  audioGerado String? // URL do áudio gerado a partir do texto (TTS)

  // Relacionamentos
  arteId  String
  arte    Arte    @relation("FeedbacksArte", fields: [arteId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  autorId String
  autor   Usuario @relation("FeedbackAutor", fields: [autorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Timestamps
  criadoEm DateTime @default(now())

  @@index([arteId])
  @@index([autorId])
  @@index([tipo])
  @@index([criadoEm])
  @@map("feedbacks")
}

// ✅ Aprovações
model Aprovacao {
  id         String  @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  status     String  @default("PENDENTE") // StatusAprovacao: PENDENTE, APROVADO, REJEITADO
  comentario String?

  // Relacionamentos
  arteId      String
  arte        Arte    @relation("AprovacoesArte", fields: [arteId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  aprovadorId String
  aprovador   Usuario @relation("AprovacaoAprovador", fields: [aprovadorId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Timestamps
  criadoEm DateTime @default(now())

  @@index([arteId])
  @@index([aprovadorId])
  @@index([status])
  @@index([criadoEm])
  @@map("aprovacoes")
}

// 📋 Tarefas
model Tarefa {
  id         String    @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  titulo     String
  descricao  String?
  status     String    @default("PENDENTE") // StatusTarefa: PENDENTE, EM_ANDAMENTO, CONCLUIDA
  prioridade String    @default("MEDIA") // Prioridade: BAIXA, MEDIA, ALTA
  prazo      DateTime?

  // Relacionamentos
  projetoId     String?
  projeto       Projeto? @relation("TarefasProjeto", fields: [projetoId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  responsavelId String
  responsavel   Usuario  @relation("TarefaResponsavel", fields: [responsavelId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Timestamps
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([projetoId])
  @@index([responsavelId])
  @@index([status])
  @@index([prioridade])
  @@index([prazo])
  @@map("tarefas")
}

// 🔔 Notificações
model Notificacao {
  id       String  @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  titulo   String
  conteudo String
  tipo     String // TipoNotificacao: SISTEMA, FEEDBACK, APROVACAO, TAREFA
  canal    String  @default("SISTEMA") // CanalNotificacao: SISTEMA, EMAIL, PUSH
  lida     Boolean @default(false)

  // Relacionamentos
  usuarioId String
  usuario   Usuario @relation("NotificacaoUsuario", fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Timestamps
  criadoEm DateTime @default(now())

  @@index([usuarioId])
  @@index([tipo])
  @@index([lida])
  @@index([criadoEm])
  @@map("notificacoes")
}

// 🔐 Sessões (para JWT/Auth)
model Sessao {
  id               String    @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  token            String    @unique
  expiresAt        DateTime
  refreshToken     String?   @unique
  refreshExpiresAt DateTime?
  ativo            Boolean   @default(true)

  // Relacionamentos
  usuarioId String
  usuario   Usuario @relation("SessaoUsuario", fields: [usuarioId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  // Timestamps
  criadoEm DateTime @default(now())

  @@index([usuarioId])
  @@index([token])
  @@index([refreshToken])
  @@index([expiresAt])
  @@index([ativo])
  @@map("sessoes")
}

// 📝 Audit Logs
model AuditLog {
  id String @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))

  action     String  @db.Text
  resource   String  @db.Text
  resourceId String? @db.Text

  details   Json?   @db.JsonB
  ipAddress String? @db.Text
  userAgent String? @db.Text

  status       String  @db.Text
  errorMessage String? @db.Text

  usuarioId String?
  usuario   Usuario? @relation("AuditLogUsuario", fields: [usuarioId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  criadoEm DateTime @default(now())

  @@index([usuarioId])
  @@index([action])
  @@index([resource])
  @@index([status])
  @@index([criadoEm])
  @@map("audit_logs")
}

// 🔒 Security Events
model SecurityEvent {
  id String @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))

  eventType String @db.Text
  severity  String @db.Text

  description String @db.Text
  details     Json?  @db.JsonB

  ipAddress String? @db.Text
  userAgent String? @db.Text
  location  String? @db.Text

  usuarioId String?
  usuario   Usuario? @relation("SecurityEventUsuario", fields: [usuarioId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String?   @db.Text

  criadoEm DateTime @default(now())

  @@index([usuarioId])
  @@index([eventType])
  @@index([severity])
  @@index([resolved])
  @@index([criadoEm])
  @@map("security_events")
}

// 🔗 Links Compartilhados
model LinkCompartilhado {
  id String @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))

  token String @unique
  tipo  String @db.Text

  arteId String?
  arte   Arte?   @relation("LinksArte", fields: [arteId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  somenteLeitura Boolean   @default(true)
  expiraEm       DateTime?

  criadoEm DateTime @default(now())

  @@index([token])
  @@index([arteId])
  @@index([expiraEm])
  @@map("link_compartilhado")
}

// ====== SISTEMA DE PAGAMENTOS ======

// 💰 Planos de Assinatura
model Plano {
  id               String  @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  nome             String // FREE | PRO | BUSINESS
  tipo             String // DESIGNER | CLIENTE
  precoMensal      Int // Em centavos (0 para FREE)
  precoAnual       Int? // Em centavos
  taxaPlataforma   Float   @default(0.10) // Percentual: 0.10 = 10%
  limitesProjetos  Int? // null = ilimitado
  limitesArtes     Int?
  limitesStorageMb Int?
  descricao        String?
  ativo            Boolean @default(true)

  assinaturas Assinatura[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([tipo])
  @@index([ativo])
  @@map("planos")
}

// 📋 Assinaturas
model Assinatura {
  id                  String    @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  status              String    @default("PENDENTE") // PENDENTE | ATIVA | CANCELADA | PAUSADA | EXPIRADA
  periodoInicio       DateTime?
  periodoFim          DateTime?
  renovacaoAutomatica Boolean   @default(true)
  mpPreapprovalId     String?   @unique // ID da preapproval no MercadoPago
  mpPlanId            String? // ID do plano no MercadoPago

  usuarioId String
  usuario   Usuario @relation("AssinaturaUsuario", fields: [usuarioId], references: [id], onDelete: Cascade)
  planoId   String
  plano     Plano   @relation(fields: [planoId], references: [id])

  pagamentos Pagamento[] @relation("PagamentosAssinatura")

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([usuarioId])
  @@index([status])
  @@map("assinaturas")
}

// 🧾 Faturas (cobranças de projeto)
model Fatura {
  id                   String    @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  valor                Int // Total em centavos
  taxaPlataforma       Int // Taxa VIU em centavos
  valorLiquidoDesigner Int // Valor que o designer recebe em centavos
  status               String    @default("PENDENTE") // PENDENTE | PAGA | CANCELADA | ESTORNADA
  dataVencimento       DateTime?
  dataPagamento        DateTime?
  descricao            String?

  projetoId  String
  projeto    Projeto @relation("FaturasProjeto", fields: [projetoId], references: [id])
  clienteId  String
  cliente    Usuario @relation("FaturasCliente", fields: [clienteId], references: [id])
  designerId String
  designer   Usuario @relation("FaturasDesigner", fields: [designerId], references: [id])

  pagamento Pagamento? @relation("PagamentoFatura")
  disputas  Disputa[]  @relation("DisputasFatura")

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([projetoId])
  @@index([clienteId])
  @@index([designerId])
  @@index([status])
  @@map("faturas")
}

// 💳 Pagamentos
model Pagamento {
  id              String  @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  tipo            String // ASSINATURA | FATURA
  status          String  @default("PENDENTE") // PENDENTE | PROCESSANDO | APROVADO | REJEITADO | CANCELADO | ESTORNADO
  valor           Int // Em centavos
  metodoPagamento String? // PIX | CARTAO_CREDITO | BOLETO
  mpPaymentId     String? @unique // ID do pagamento no MercadoPago
  mpPreferenceId  String? // ID da preferência de checkout
  mpStatus        String? // Status original do MercadoPago
  mpQrCode        String? // QR code PIX em base64
  mpQrCodeText    String? // Texto do PIX copia-e-cola

  usuarioId    String
  usuario      Usuario     @relation("PagamentosUsuario", fields: [usuarioId], references: [id])
  assinaturaId String?
  assinatura   Assinatura? @relation("PagamentosAssinatura", fields: [assinaturaId], references: [id])
  faturaId     String?     @unique
  fatura       Fatura?     @relation("PagamentoFatura", fields: [faturaId], references: [id])

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([usuarioId])
  @@index([status])
  @@index([tipo])
  @@index([mpPaymentId])
  @@map("pagamentos")
}

// 🏦 Chaves PIX dos Designers
model ChavePix {
  id      String  @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  tipo    String // CPF | EMAIL | TELEFONE | ALEATORIA
  chave   String
  titular String
  ativa   Boolean @default(true)

  usuarioId String
  usuario   Usuario @relation("ChavesPixUsuario", fields: [usuarioId], references: [id], onDelete: Cascade)

  saques Saque[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([usuarioId])
  @@map("chaves_pix")
}

// 💸 Saques
model Saque {
  id         String  @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  valor      Int // Em centavos
  status     String  @default("SOLICITADO") // SOLICITADO | PROCESSANDO | CONCLUIDO | REJEITADO
  mpPayoutId String? @unique

  designerId String
  designer   Usuario  @relation("SaquesDesigner", fields: [designerId], references: [id])
  chavePixId String
  chavePix   ChavePix @relation(fields: [chavePixId], references: [id])

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([designerId])
  @@index([status])
  @@map("saques")
}

// ====== PROTEÇÃO LEGAL ======

// 📜 Aceite Contratual (Lei 14.063/20 – validade da assinatura eletrônica)
model AceiteContratual {
  id          String  @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  termoVersao String  @default("1.0")
  ip          String?
  userAgent   String?

  usuarioId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  projetoId String
  projeto   Projeto @relation(fields: [projetoId], references: [id], onDelete: Cascade)

  criadoEm DateTime @default(now())

  @@unique([usuarioId, projetoId])
  @@index([usuarioId])
  @@index([projetoId])
  @@map("aceites_contratuais")
}

// ⚖️ Disputas (canal de denúncia / mediação)
model Disputa {
  id             String    @id @default(dbgenerated("'c' || encode(gen_random_bytes(12), 'hex')"))
  // CALOTE | ENTREGA_INCOMPLETA | FRAUDE | OUTRO
  tipo           String
  // ABERTA | EM_ANALISE | RESOLVIDA_DESIGNER | RESOLVIDA_CLIENTE | ESCALADA
  status         String    @default("ABERTA")
  descricao      String
  resolucao      String?
  saldoBloqueado Int       @default(0) // centavos bloqueados durante a disputa
  resolvidaEm    DateTime?

  abertaPorId String
  abertaPor   Usuario @relation("DisputasAbertas", fields: [abertaPorId], references: [id])
  projetoId   String
  projeto     Projeto @relation(fields: [projetoId], references: [id])
  faturaId    String?
  fatura      Fatura? @relation("DisputasFatura", fields: [faturaId], references: [id])

  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([projetoId])
  @@index([abertaPorId])
  @@index([status])
  @@map("disputas")
}

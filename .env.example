# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/viu"

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="substitua_por_uma_chave_aleatoria_de_no_minimo_32_caracteres"
JWT_EXPIRES_IN=7d

# CORS — origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:3000

# URL pública do frontend (usada em links compartilhados)
FRONTEND_URL=http://localhost:3000

# Supabase Storage (apenas para armazenamento de arquivos)
SUPABASE_URL=https://<projeto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# OpenAI (opcional — transcrição e TTS de feedbacks de áudio)
OPENAI_API_KEY=
